# ============================================================
# claw-quant-data 环境变量配置模板
# ============================================================
# 复制此文件为 .env 后填写真实值
#   cp .env.example .env
# ============================================================

# PostgreSQL 连接配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=tushare_db
DB_USER=tushare
DB_PASSWORD=你的数据库密码

# Tushare Pro Token（可选，已入库则不需要）
TUSHARE_TOKEN=你的tushare_token

# 通知渠道（可选，默认只打日志）
# NOTIFIER_TYPE=dingtalk

# 钉钉通知配置（NOTIFIER_TYPE=dingtalk 时生效）
# DINGTALK_USER_ID=你的钉钉userId
